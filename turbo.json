{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "GCS_PROJECT_ID",
    "GCS_CLIENT_EMAIL",
    "GCS_PRIVATE_KEY",
    "GCS_BUCKET_NAME",
    "NEXTAUTH_SECRET"
  ],
  "tasks": {
    "migrate": {
      "cache": false
    },
    "push": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "studio": {
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "dependsOn": ["^clean"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
